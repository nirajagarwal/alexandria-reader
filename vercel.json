{
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/css/(.*)",
            "destination": "/frontend/css/$1"
        },
        {
            "source": "/js/(.*)",
            "destination": "/frontend/js/$1"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/frontend/assets/$1"
        },
        {
            "source": "/outputs/(.*)",
            "destination": "/outputs/$1"
        },
        {
            "source": "/robots.txt",
            "destination": "/frontend/robots.txt"
        },
        {
            "source": "/sitemap.xml",
            "destination": "/frontend/sitemap.xml"
        },
        {
            "source": "/manifest.json",
            "destination": "/frontend/manifest.json"
        },
        {
            "source": "/book.html",
            "destination": "/frontend/book.html"
        },
        {
            "source": "/",
            "destination": "/frontend/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/api/main.py"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                }
            ]
        }
    ]
}